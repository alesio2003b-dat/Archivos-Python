##En este proyecto se busca calcular la probabilidad de que, al tirar un dado 100 veces, estés por encima del nivel 60 de un rascacielos de 100 pisos, siguiendo las siguientes condiciones:
#Si el dado sale 1-2 bajas un piso
#Si el dado sale 3-4-5 subis un piso
#Si el dado sale 6 subis los pisos según una nueva tirada.
#Además se cuenta con una probabilidad del 0.1% de si se cae en las escaleras se vuelve al piso 0.

import numpy as np
import matplotlib.pyplot as plt

# Simulate random walk 500 times
all_walks = []
for i in range(500) :
    random_walk = [0]
    for x in range(100) :
        step = random_walk[-1]
        dice = np.random.randint(1,7)
        if dice <= 2:
            step = max(0, step - 1)
        elif dice <= 5:
            step = step + 1
        else:
            step = step + np.random.randint(1,7)
        if np.random.rand() <= 0.001 :
            step = 0
        random_walk.append(step)
    all_walks.append(random_walk)

#Creo np_aw_t traspuesto
